# Copy this to .env (in the repo root) and fill in. deploy.sh loads it
# automatically; .env is gitignored so secrets stay out of the repo.

# Google AdSense publisher ID — verifies the site and enables ads.
# Example: ca-pub-9360752375665568
ADSENSE_CLIENT=

# AdSense display ad-unit slot ID (the data-ad-slot number from the unit you
# create in AdSense). Without it, ad spots show a reserved placeholder.
ADSENSE_SLOT=

# NASA NeoWs API key for the dashboard's Near-Earth Asteroids signal.
# DEMO_KEY works but is rate-limited; get a free key at https://api.nasa.gov/
NASA_API_KEY=
